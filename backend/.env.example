# =============================================================================
# VoiceTutor — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill values. Never commit `.env`.
#
# Stack (all free tiers, no card required):
#   LLM  → Groq Llama 3.3 70B
#   STT  → AssemblyAI Universal-Streaming  ($50 free credit, no card)
#   TTS  → ElevenLabs Turbo v2.5           (10k chars/mo free)
#   VAD  → Silero (local, no key)
# =============================================================================

# --- LLM: Groq --------------------------------------------------------------
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- STT: AssemblyAI Universal-Streaming ------------------------------------
# Get key: https://www.assemblyai.com/app/api-keys  (signup gives $50 credit)
ASSEMBLYAI_API_KEY=

# Leave blank to auto-detect language per utterance (best for code-switching).
# Force a single language with 'es' or 'en' if auto-detect misbehaves.
ASSEMBLYAI_LANGUAGE=

# --- TTS provider switch ----------------------------------------------------
#   TTS_PROVIDER=elevenlabs   → best voice quality, 10k chars/mo free (DEFAULT)
#   TTS_PROVIDER=deepgram     → cheaper at scale BUT requires Deepgram credit
TTS_PROVIDER=elevenlabs

# --- ElevenLabs (active when TTS_PROVIDER=elevenlabs) -----------------------
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Optional per-language ElevenLabs voice IDs (for future routing)
VOICE_ID_EN=EXAVITQu4vr4xnSDxMaL
VOICE_ID_ES=Nh2zY9kknu6z4pZy6FhD

# --- Deepgram (OPTIONAL — only when TTS_PROVIDER=deepgram, or STT fallback) -
# Newer Deepgram accounts no longer get the $200 free credit automatically.
# Leave this section as-is unless you've added Deepgram credit.
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-2-general
DEEPGRAM_LANGUAGE=multi
# Voices: aura-2-celeste-es (ES female) | aura-2-sirio-es (ES male) | aura-asteria-en (EN)
DEEPGRAM_TTS_VOICE=aura-2-celeste-es

# --- Server -----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Persistence ------------------------------------------------------------
SQLITE_PATH=./data/voicetutor.db

# --- Hardcoded single-user mode (assignment-allowed shortcut) ---------------
DEFAULT_USER_ID=demo-user-001
DEFAULT_USER_NAME=Learner
DEFAULT_NATIVE_LANG=en
DEFAULT_TARGET_LANG=es

# --- Audio gating -----------------------------------------------------------
# false (default) = headphones — bot can be barged-in freely.
# true  = speakers — turns on echo gate so bot doesn't transcribe its own audio.
MIC_GATE_ENABLED=false

# --- Observability ----------------------------------------------------------
ENABLE_PER_TURN_LOGS=true
LATENCY_LOG_PATH=./logs/turn_latency.jsonl
